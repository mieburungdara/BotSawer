# =============================================
# BOTSAWER - TELEGRAM CONTENT MONETIZATION BOT
# Complete Environment Configuration
# =============================================

# =============================================
# APPLICATION SETTINGS
# =============================================
# Application name displayed in web interface and logs
APP_NAME=BotSawer

# Environment: production, staging, development, local
APP_ENV=production

# Debug mode: true untuk development (menampilkan error detail), false untuk production
APP_DEBUG=false

# Application URL: base URL untuk webapp dan webhook
APP_URL=https://yourdomain.com

# Timezone: zona waktu aplikasi (gunakan Asia/Jakarta untuk Indonesia)
APP_TIMEZONE=Asia/Jakarta

# =============================================
# DATABASE CONFIGURATION
# =============================================
# Database connection type: mysql, pgsql, sqlite, sqlsrv
DB_CONNECTION=mysql

# Database host: localhost untuk server lokal, atau IP server database
DB_HOST=localhost

# Database port: 3306 untuk MySQL, 5432 untuk PostgreSQL
DB_PORT=3306

# Database name: nama database yang telah dibuat
DB_NAME=botsawer

# Database username: user database dengan akses penuh
DB_USER=your_db_user

# Database password: password untuk user database
DB_PASSWORD=your_db_password

# =============================================
# TELEGRAM BOT CONFIGURATION (Dual Bot System)
# =============================================
# USER BOT - Bot untuk interaksi user biasa & kreator
# Token bot dari @BotFather (bot utama untuk user interaction)
TELEGRAM_USER_BOT_TOKEN=your_user_bot_token_here

# Username bot user (dengan @, dari @BotFather)
TELEGRAM_USER_BOT_USERNAME=@your_user_bot_username

# Webhook secret untuk user bot (gunakan string acak yang aman)
TELEGRAM_USER_WEBHOOK_SECRET=user_secret

# MODERATOR BOT - Bot untuk admin & content management (admin only)
# Token bot moderator dari @BotFather (bot khusus untuk admin)
TELEGRAM_MODERATOR_BOT_TOKEN=your_moderator_bot_token_here

# Username bot moderator (dengan @)
TELEGRAM_MODERATOR_BOT_USERNAME=@your_moderator_bot_username

# LEGACY SUPPORT - untuk kompatibilitas kode lama
# Otomatis mengarah ke user bot token/secret
TELEGRAM_BOT_TOKEN=${TELEGRAM_USER_BOT_TOKEN}
TELEGRAM_WEBHOOK_SECRET=${TELEGRAM_USER_WEBHOOK_SECRET}
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/public/webhook.php

# =============================================
# PAYMENT CONFIGURATION
# =============================================
# Rekening admin untuk informasi pembayaran (format: BANK - NO_REK - NAMA)
PAYMENT_ADMIN_BANK_ACCOUNT=BCA - 1234567890 - Admin Name

# =============================================
# SYSTEM SETTINGS
# =============================================
# Komisi platform dalam persen (0-100, contoh: 10.00 untuk 10%)
PLATFORM_COMMISSION=10.00

# Minimal deposit/topup dalam rupiah
MIN_DEPOSIT=10000.00

# Minimal penarikan dalam rupiah
MIN_WITHDRAW=50000.00

# Mode maintenance: 0=normal, 1=maintenance (user tidak bisa akses)
MAINTENANCE_MODE=0

# =============================================
# LOGGING CONFIGURATION
# =============================================
# Log level: emergency, alert, critical, error, warning, notice, info, debug
# - emergency: sistem tidak bisa beroperasi
# - alert: perlu tindakan segera
# - critical: error kritis
# - error: error aplikasi
# - warning: peringatan yang perlu diperhatikan
# - notice: informasi penting
# - info: informasi umum operasi (recommended untuk production)
# - debug: informasi detail untuk development
LOG_LEVEL=info

# Maksimal jumlah file log yang disimpan (rotasi otomatis)
LOG_MAX_FILES=30

# =============================================
# SECURITY & RATE LIMITING
# =============================================
# Enable rate limiting: true/false
RATE_LIMIT_ENABLED=true

# Maksimal request per window time
RATE_LIMIT_REQUESTS=100

# Window time dalam detik (3600 = 1 jam)
RATE_LIMIT_WINDOW=3600