# =============================================
# BOTSAWER - TELEGRAM CONTENT MONETIZATION BOT
# Complete Environment Configuration
# =============================================

# =============================================
# APPLICATION SETTINGS
# =============================================
APP_NAME=BotSawer
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Asia/Jakarta
APP_SECRET=your_random_secret_string_here

# =============================================
# DATABASE CONFIGURATION
# =============================================
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=botsawer
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# =============================================
# TELEGRAM BOT CONFIGURATION (Dual Bot System)
# =============================================
# User Bot - untuk interaksi user biasa & kreator
TELEGRAM_USER_BOT_TOKEN=your_user_bot_token_here
TELEGRAM_USER_BOT_USERNAME=@your_user_bot_username
TELEGRAM_USER_WEBHOOK_SECRET=user_secret

# Moderator Bot - untuk admin & content management (admin only)
TELEGRAM_MODERATOR_BOT_TOKEN=your_moderator_bot_token_here
TELEGRAM_MODERATOR_BOT_USERNAME=@your_moderator_bot_username
# Moderator webhook secret rotates daily: moderator_YYYY-MM-DD

# Legacy support (auto-points to user bot)
TELEGRAM_BOT_TOKEN=${TELEGRAM_USER_BOT_TOKEN}
TELEGRAM_WEBHOOK_SECRET=${TELEGRAM_USER_WEBHOOK_SECRET}
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/public/webhook.php

# =============================================
# ADMIN CONFIGURATION
# =============================================
ADMIN_TELEGRAM_ID=123456789
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NAME=Administrator

# =============================================
# PAYMENT CONFIGURATION
# =============================================
PAYMENT_ADMIN_BANK_ACCOUNT=BCA - 1234567890 - Admin Name
PAYMENT_QR_DATA=00020101021126660014BRIN6016ID10230000200000002020200000000000000303UME51440014ID.CO.QRIS.WWW0215ID10230000200000303UME5204581253033605802ID5916Admin Name6013Jakarta Pusat610512340

# Midtrans Payment Gateway (Optional)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_ENVIRONMENT=sandbox
MIDTRANS_MERCHANT_ID=your_merchant_id

# =============================================
# SYSTEM SETTINGS
# =============================================
PLATFORM_COMMISSION=10.00
MIN_DEPOSIT=10000.00
MIN_WITHDRAW=50000.00
MAINTENANCE_MODE=0

# =============================================
# CHANNEL CONFIGURATION
# =============================================
PUBLIC_CHANNEL=@your_public_channel
BACKUP_CHANNEL=@your_backup_channel

# =============================================
# LOGGING CONFIGURATION
# =============================================
LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_MAX_FILES=30
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_SLACK_WEBHOOK_URL=

# =============================================
# CACHE CONFIGURATION
# =============================================
CACHE_DRIVER=file
CACHE_PREFIX=botsawer_
CACHE_DEFAULT_TTL=3600

# =============================================
# SESSION CONFIGURATION
# =============================================
SESSION_DRIVER=file
SESSION_LIFETIME=7200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================
# SECURITY & RATE LIMITING
# =============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_BACKOFF=60

# =============================================
# EMAIL CONFIGURATION (Optional)
# =============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USERNAME=your_email@yourdomain.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME=BotSawer

# =============================================
# QUEUE CONFIGURATION (Optional)
# =============================================
QUEUE_CONNECTION=database
QUEUE_TABLE=jobs
QUEUE_FAILED_DRIVER=database
QUEUE_FAILED_TABLE=failed_jobs

# =============================================
# FILESYSTEM CONFIGURATION
# =============================================
FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your_bucket_name

# =============================================
# MONITORING & ANALYTICS (Optional)
# =============================================
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=your_google_analytics_id

# =============================================
# THIRD-PARTY INTEGRATIONS (Optional)
# =============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =============================================
# DEVELOPMENT SETTINGS
# =============================================
DEVELOPMENT_MODE=false
DEBUG_QUERIES=false
LOG_QUERIES=false