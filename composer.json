{
    "name": "botsawer/telegram-creator-payment",
    "description": "Bot Telegram sistem pembayaran otomatis untuk kreator konten foto dan video",
    "type": "project",
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-mysqli": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "irazasyed/telegram-bot-sdk": "^3.0",
        "illuminate/database": "^8.0",
        "vlucas/phpdotenv": "^4.0",
        "monolog/monolog": "^2.0",
        "respect/validation": "^1.0",
        "midtrans/midtrans-php": "^2.0",
        "guzzlehttp/guzzle": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "symfony/var-dumper": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "BotSawer\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {

        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
